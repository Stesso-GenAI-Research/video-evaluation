{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/action-semantics/original-rankings.schema.json",
  "title": "One query with its original ranked clip results",
  "type": "object",
  "additionalProperties": false,
  "required": ["step_id", "query", "original_matches"],
  "properties": {
    "step_id": {
      "type": "string",
      "minLength": 1
    },
    "query": {
      "type": "string",
      "minLength": 1
    },
    "original_matches": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["rank"],
        "anyOf": [
          {"required": ["clip_id"]},
          {"required": ["video_id", "start_seconds", "end_seconds"]}
        ],
        "properties": {
          "clip_id": {
            "type": "string",
            "minLength": 1
          },
          "video_id": {
            "type": ["string", "integer"]
          },
          "start_seconds": {
            "type": "number",
            "minimum": 0
          },
          "end_seconds": {
            "type": "number",
            "exclusiveMinimum": 0
          },
          "rank": {
            "type": "integer",
            "minimum": 1
          }
        }
      }
    }
  }
}
