{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/action-semantics/original-rankings.schema.json",
  "title": "One query with its original ranked clip results",
  "type": "object",
  "additionalProperties": false,
  "required": ["step_id", "query", "original_matches"],
  "properties": {
    "step_id": {
      "type": "string",
      "minLength": 1
    },
    "query": {
      "type": "string",
      "minLength": 1
    },
    "original_matches": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["clip_id", "rank"],
        "properties": {
          "clip_id": {
            "type": "string",
            "minLength": 1
          },
          "rank": {
            "type": "integer",
            "minimum": 1
          }
        }
      }
    }
  }
}
